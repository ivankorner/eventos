# ===================================================
# SISTEMA DE INSCRIPCIONES — Variables de Entorno
# Copiar este archivo como .env y completar los valores
# NUNCA subir el archivo .env al repositorio
# ===================================================

# Entorno de ejecución
APP_ENV=local
# local | production
APP_DEBUG=true
APP_URL=http://localhost/parlamentos/public
APP_NAME="Sistema de Inscripciones"

# Clave secreta de la aplicación (generar con: openssl rand -hex 16)
APP_KEY=cambia_esta_clave_por_una_aleatoria_de_32_chars

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inscripciones_db
DB_USER=root
DB_PASS=

# Email (SMTP) - Servidor propietario appcde.online
MAIL_DRIVER=smtp
MAIL_HOST=appcde.online
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=no-reply@appcde.online
MAIL_PASSWORD="A26_H3{/N]z<"
MAIL_FROM_ADDRESS=no-reply@appcde.online
MAIL_FROM_NAME="Sistema de Inscripciones"

# Seguridad
CSRF_TOKEN_LIFETIME=3600
SESSION_LIFETIME=7200
SESSION_NAME=insc_session

# Archivos
UPLOAD_MAX_SIZE=5242880
# 5MB en bytes
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,webp
UPLOAD_PATH=../public/uploads

# Rate limiting (inscripciones públicas)
RATE_LIMIT_SUBMISSIONS=5
# máximo envíos por IP en la ventana
RATE_LIMIT_WINDOW=3600
# ventana en segundos
