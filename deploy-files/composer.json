{
    "name": "sistema/inscripciones",
    "description": "Sistema de Gestión de Formularios de Inscripción para Eventos",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpspreadsheet": "^2.1"
    },
    "autoload": {
        "classmap": [
            "app/Controllers/",
            "app/Models/",
            "app/Helpers/",
            "app/Middleware/",
            "config/database.php",
            "config/routes.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
