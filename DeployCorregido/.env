# ===================================================
# PRODUCCIÓN — Don Web Shared Hosting
# Copiar este archivo como .env una vez en el servidor
# NUNCA subir este archivo al repositorio
# ===================================================

# Entorno de ejecución
APP_ENV=production
# Cambiar a false en producción (NUNCA true)
APP_DEBUG=false
# URL HTTPS del dominio apuntando a /eventos/public/
APP_URL=https://appcde.online/eventos/public
APP_NAME="Sistema de Inscripciones"

# Clave secreta de la aplicación
# GENERAR UNA NUEVA: openssl rand -hex 32
# Reemplazar con una clave aleatoria de 64 caracteres
APP_KEY=f546e8d1fc094a3c73f2a3660ebb20d1275f6615f263ab1fab6d61d492a05bdd

# ===================================================
# BASE DE DATOS (Credenciales del servidor Don Web)
# ===================================================
# Estos datos se proporcionan en el panel de Don Web
# en la sección de "Bases de Datos MySQL"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=appc_parlamentos
DB_USER=appc_parlamentos
DB_PASS=DbkI7RUBM7ulJlik

# ===================================================
# CORREO ELECTRÓNICO (SMTP)
# ===================================================
# Se recomienda usar Gmail con contraseña de aplicación
# O el servidor SMTP que proporcione Don Web
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=datos.cdeldorado@gmail.com
MAIL_PASSWORD=kmvlxfcvkjvnytkv
MAIL_FROM_ADDRESS=datos.cdeldorado@gmail.com
MAIL_FROM_NAME="Sistema de Inscripciones"

# ===================================================
# SEGURIDAD
# ===================================================
# Tiempo de vida de tokens CSRF en segundos (1 hora)
CSRF_TOKEN_LIFETIME=3600
# Tiempo de vida de sesión en segundos (2 horas)
SESSION_LIFETIME=7200
SESSION_NAME=insc_session

# ===================================================
# ARCHIVOS Y UPLOADS
# ===================================================
# Tamaño máximo de upload en bytes (5MB)
UPLOAD_MAX_SIZE=5242880
# Tipos de archivo permitidos
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,webp
# Ruta relativa de uploads (relativa a BASE_PATH/public)
UPLOAD_PATH=../public/uploads

# ===================================================
# RATE LIMITING (protección contra spam)
# ===================================================
# Máximo de inscripciones por IP en la ventana
RATE_LIMIT_SUBMISSIONS=5
# Ventana de tiempo en segundos (1 hora)
RATE_LIMIT_WINDOW=3600
